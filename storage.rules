rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for images and PDFs used in lessons
    match /images/{allImages=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /pdfs/{allPdfs=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Book content images (externalized from base64) — public read, auth write
    match /books/{allBookAssets=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // inquiry-questions images — public read, auth write
    match /inquiry-questions/{allIqAssets=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Deny everything else by default
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
